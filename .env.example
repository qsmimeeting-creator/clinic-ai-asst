# Gemini API Key (Required)
# You can provide multiple keys separated by commas for load balancing
GEMINI_API_KEY=

# Vercel KV (Redis) - Required for persistence
# These are automatically provided by Vercel when you connect a KV database
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Vercel Blob - Required for file storage
# This is automatically provided by Vercel when you connect a Blob store
BLOB_READ_WRITE_TOKEN=

# Node Environment
NODE_ENV=development
